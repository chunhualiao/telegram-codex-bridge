<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.example.telegram-codex-bridge</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/path/to/telegram-codex-bridge/run-bridge.sh</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>WorkingDirectory</key>
  <string>/path/to/telegram-codex-bridge</string>
  <key>StandardOutPath</key>
  <string>/path/to/telegram-codex-bridge/state/stdout.log</string>
  <key>StandardErrorPath</key>
  <string>/path/to/telegram-codex-bridge/state/stderr.log</string>
</dict>
</plist>
